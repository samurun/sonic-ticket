{
  "name": "sonic-ticket",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @workspace/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @workspace/db db:migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @workspace/db db:push",
    "db:studio": "dotenv -e .env -- pnpm --filter @workspace/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
