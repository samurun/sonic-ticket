# ============================================================
# Sonic Ticket — single env file for local dev + docker compose
# ============================================================
# Copy to .env and fill in passwords.

# App
APP_PORT=4000
WEB_PORT=3000

# Public API URL (baked into the Next.js client bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sonic-db
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RedisInsight
REDISINSIGHT_HOST=localhost
REDISINSIGHT_PORT=8001

# Mock payment processing delay in milliseconds (0 to disable)
MOCK_PAYMENT_DELAY_MS=0
